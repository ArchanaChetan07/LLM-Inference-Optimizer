{
  "title": "LLM Inference Cost/Latency/Quality Optimizer",
  "schemaVersion": 39,
  "panels": [
    {
      "title": "Requests/sec by config",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(gateway_requests_total[1m])) by (config)" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "P95 End-to-End Latency by config",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(gateway_e2e_seconds_bucket[5m])) by (le, config))" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Time to First Token (P50/P95)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(gateway_ttft_seconds_bucket[5m])) by (le, config))", "legendFormat": "p50-{{config}}" },
        { "expr": "histogram_quantile(0.95, sum(rate(gateway_ttft_seconds_bucket[5m])) by (le, config))", "legendFormat": "p95-{{config}}" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "title": "Queue Depth (drives HPA)",
      "type": "timeseries",
      "targets": [
        { "expr": "gateway_queue_depth" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "title": "Tokens Generated/sec by config",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(gateway_tokens_generated_total[1m])) by (config)" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "title": "Speculative Decode Acceptance Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "gateway_spec_decode_acceptance_rate" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    },
    {
      "title": "Cost per 1M Tokens (from cost_calculator.py output, via pushgateway or static panel)",
      "type": "table",
      "description": "Populate by pushing benchmark/results/cost_report.json to a Prometheus Pushgateway, or paste values manually as a text panel until automated.",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 24 }
    }
  ]
}
